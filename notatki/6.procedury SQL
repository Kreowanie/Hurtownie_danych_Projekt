        END;
        GO




        CREATE OR ALTER PROCEDURE [dbo].[importTransactionType]
        AS
        BEGIN

            INSERT INTO dbo.DimTransactionType
            (
                TransactionType,
                IsCancelled,
                IsReturn
            )
            SELECT DISTINCT
                sc.TransactionType,
                sc.IsCancelled,
                sc.IsReturn
            FROM dbo.SalesClean sc
            LEFT JOIN dbo.DimTransactionType dtran
                ON ISNULL(dtran.TransactionType, '') = ISNULL(sc.TransactionType, '')
               AND ISNULL(dtran.IsCancelled, 0) = ISNULL(sc.IsCancelled, 0)
               AND ISNULL(dtran.IsReturn, 0) = ISNULL(sc.IsReturn, 0)
            WHERE dtran.TransactionTypeKey IS NULL
              AND sc.TransactionType IS NOT NULL;

        END;
        GO


